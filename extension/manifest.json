{
  "manifest_version": 3,
  "name": "StoryHub",
  "version": "0.1.0",
  "description": "AO3 capture, status badges, and sync for StoryHub (personal use).",
  "permissions": ["storage", "alarms", "declarativeNetRequestWithHostAccess"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "host_permissions": [
    "https://ffstoryhub.up.railway.app/*",
    "https://archiveofourown.org/*",
    "https://download.archiveofourown.org/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "cors", "enabled": true, "path": "rules.json" }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "StoryHub"
  },
  "content_scripts": [
    {
      "matches": ["https://archiveofourown.org/*"],
      "js": [
        "lib/storage.js",
        "lib/badge.js",
        "lib/ao3.js",
        "lib/api.js",
        "lib/capture.js",
        "content/badges.js",
        "content/work.js",
        "content/drawer.js"
      ],
      "css": ["content/badges.css", "content/work.css", "content/drawer.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
